rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection
    match /admins/{email} {
      allow get: if request.auth != null && 
                  request.auth.token.email_verified == true && 
                  request.auth.token.email == email;
    }

    // Blogs collection
    match /blogs/{blogId} {
      // Helper: Is the user an admin?
      function isAdmin() {
        return request.auth != null && 
               exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()));
      }

      // Read rules: 
      // 1. Admins can read everything
      // 2. Others can read only published blogs
      allow get, list: if isAdmin() || resource.data.status == 'published';

      // Write rules: Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }
  }
}
